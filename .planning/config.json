{
  "project": "valtra",
  "version": "0.1.0",
  "created": "2026-03-06",
  "workflow": {
    "research_enabled": false,
    "parallel_agents": true,
    "auto_commit": true,
    "test_before_commit": true
  },
  "quality": {
    "min_coverage": 80,
    "require_tests": true,
    "lint_on_save": true
  },
  "localization": {
    "default_locale": "en",
    "supported_locales": ["en", "de"]
  },
  "design": {
    "primary_color": "#5F4A8B",
    "accent_color": "#FEFACD",
    "ui_framework": "liquid_glass"
  },
  "ci": {
    "provider": "github_actions",
    "coverage_provider": "codecov"
  }
}
