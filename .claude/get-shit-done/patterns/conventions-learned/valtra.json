{
  "project": "valtra",
  "captured_at": "2026-03-07",
  "language": {
    "primary": "dart",
    "version": "^3.10.0"
  },
  "framework": {
    "name": "flutter",
    "patterns": ["provider", "drift", "material3", "sharedpreferences", "fl_chart"]
  },
  "naming": {
    "files": {
      "pattern": "snake_case",
      "examples": ["app_theme.dart", "test_database.dart", "app_database.dart", "household_dao.dart", "household_provider.dart"]
    },
    "classes": {
      "pattern": "PascalCase",
      "examples": ["AppTheme", "AppColors", "ThemeProvider", "HouseholdDao", "HouseholdProvider"]
    },
    "variables": {
      "pattern": "camelCase",
      "examples": ["lightTheme", "darkTheme", "householdId", "selectedHousehold"]
    },
    "constants": {
      "pattern": "camelCase (static)",
      "examples": ["ultraViolet", "lemonChiffon", "_selectedHouseholdKey"]
    },
    "tables": {
      "pattern": "PascalCase plural",
      "examples": ["Households", "ElectricityReadings", "WaterMeters"]
    },
    "entities": {
      "pattern": "PascalCase singular (via @DataClassName)",
      "examples": ["Household", "ElectricityReading", "WaterMeter"]
    },
    "daos": {
      "pattern": "{Entity}Dao",
      "examples": ["HouseholdDao"]
    },
    "providers": {
      "pattern": "{Entity}Provider",
      "examples": ["ThemeProvider", "HouseholdProvider"]
    },
    "screens": {
      "pattern": "{Entity}sScreen (plural)",
      "examples": ["HouseholdsScreen"]
    },
    "dialogs": {
      "pattern": "{Entity}FormDialog",
      "examples": ["HouseholdFormDialog"]
    }
  },
  "structure": {
    "lib": {
      "database": ["tables.dart", "app_database.dart", "connection/native.dart"],
      "database/daos": ["{entity}_dao.dart"],
      "providers": ["theme_provider.dart", "{entity}_provider.dart", "{domain}_settings_provider.dart"],
      "services": ["{conversion}_service.dart"],
      "services/{domain}": ["models.dart", "{domain}_service.dart", "reading_converters.dart"],
      "services/analytics": ["analytics_models.dart", "analytics_helpers.dart"],
      "screens": ["{entity}s_screen.dart", "analytics_screen.dart", "monthly_analytics_screen.dart"],
      "widgets": ["liquid_glass_widgets.dart", "{entity}_selector.dart"],
      "widgets/charts": ["consumption_line_chart.dart", "monthly_bar_chart.dart", "chart_legend.dart"],
      "widgets/dialogs": ["{entity}_form_dialog.dart"],
      "l10n": ["app_en.arb", "app_de.arb"]
    },
    "test": {
      "helpers": ["test_database.dart", "test_utils.dart"],
      "database": ["tables_test.dart", "{entity}_dao_test.dart"],
      "providers": ["{entity}_provider_test.dart"],
      "services": ["{conversion}_service_test.dart"],
      "services/{domain}": ["models_test.dart", "{domain}_service_test.dart", "reading_converters_test.dart"],
      "screens": ["{entity}s_screen_test.dart", "analytics_screen_test.dart", "monthly_analytics_screen_test.dart"],
      "widgets": ["{entity}_form_dialog_test.dart", "{entity}_selector_test.dart"],
      "widgets/charts": ["consumption_line_chart_test.dart", "monthly_bar_chart_test.dart", "chart_legend_test.dart"]
    }
  },
  "testing": {
    "framework": "flutter_test",
    "mocking": "mocktail",
    "database": "in-memory NativeDatabase",
    "patterns": [
      "Use createTestDatabase() factory",
      "Group tests by feature",
      "Test theme brightness separately",
      "Import drift with 'hide isNotNull, isNull'",
      "Use SharedPreferences.setMockInitialValues({}) in setUp",
      "Add Future.delayed(Duration(milliseconds: 100)) after stream operations"
    ]
  },
  "localization": {
    "method": "flutter_localizations + intl",
    "languages": ["en", "de"],
    "file_format": "ARB",
    "location": "lib/l10n/"
  },
  "ci_cd": {
    "platform": "GitHub Actions",
    "workflow": "flutter-tests.yml"
  },
  "pitfalls_learned": [
    "Drift isNotNull/isNull conflicts with flutter_test matchers - use hide in import",
    "Widget tests with ChangeNotifier streams may timeout - use pump() instead of pumpAndSettle()",
    "Value.absent check: use entry.id.present not entry.id.value == null",
    "withOpacity() deprecated - use withValues(alpha: x)",
    "JOIN queries return JoinedRow - use r.readTable(entity) to extract correct table",
    "Cascade delete requires transaction() for atomicity",
    "Grouped lists need sorted keys for consistent ordering",
    "Check parent list before showing child form dialog - show snackbar if empty",
    "Use null-aware elements [?x] instead of [if (x != null) x] to satisfy use_null_aware_elements lint",
    "Interpolation tests need millisecond precision - use inMilliseconds in both code and test expectations",
    "Self-init provider pattern: call await provider.init() in main() before runApp()",
    "ARB parameterized strings need @key metadata block with placeholders object",
    "fl_chart BarChartGroupData.x requires int - use sequential index, map to month labels in titles",
    "fl_chart has no built-in legend - build custom ChartLegend widget",
    "Multi-meter aggregation: interpolate per-meter independently, then sum - never merge raw readings",
    "FlSpot.nullSpot creates line gaps - guard with .any((s) => s != FlSpot.nullSpot) before rendering",
    "Custom date range + month navigation: navigateMonth() must clear customRange",
    "fl_chart widget tests: can't inspect canvas - focus on data transformation and widget-renders-without-crash"
  ]
}
